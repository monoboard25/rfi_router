<?xml version="1.0" encoding="utf-8"?>
<!--
  Permission Matrix — PnP Provisioning Template
  Apply with: Apply-PnPProvisioningTemplate -Path permission_matrix.pnp.xml
  Target site: Company Intranet → Agent Governance
  Constitution reference: Pillar I — Bounded Scope
  
  IMPORTANT: This list is the ONLY place Permission Matrix is enforced at runtime.
  Do not duplicate grants into agent prompts. Scope validator reads this list fresh
  on every validation call (60-second in-memory cache max).
-->
<pnp:Provisioning xmlns:pnp="http://schemas.dev.office.com/PnP/2022/09/ProvisioningSchema">
  <pnp:Preferences Generator="monoboard-agent-governance-v1.0" />
  <pnp:Templates ID="MONOBOARD-GOVERNANCE-TEMPLATES">
    <pnp:ProvisioningTemplate ID="PERMISSION-MATRIX-TEMPLATE" Version="1">

      <pnp:Lists>
        <pnp:ListInstance
          Title="PermissionMatrix"
          Description="Authoritative agent-scope access grants. Read by the scope validator on every agent write. Absence of a row = denial. Constitution ref: Pillar I."
          TemplateType="100"
          Url="Lists/PermissionMatrix"
          EnableVersioning="true"
          MaxVersionLimit="50"
          EnableAttachments="false"
          OnQuickLaunch="true">

          <pnp:Fields>

            <!-- agent_id: which agent holds this grant -->
            <Field Type="Choice"
                   DisplayName="agent_id"
                   Name="agent_id"
                   ID="{A1000001-0000-0000-0000-000000000001}"
                   Required="TRUE"
                   EnforceUniqueValues="FALSE">
              <CHOICES>
                <CHOICE>rfi_router</CHOICE>
                <CHOICE>daily_report</CHOICE>
                <CHOICE>change_order</CHOICE>
                <CHOICE>safety_monitor</CHOICE>
                <CHOICE>bid_assist</CHOICE>
                <CHOICE>ceo_agent</CHOICE>
              </CHOICES>
            </Field>

            <!-- scope_id: the logical scope being granted -->
            <Field Type="Choice"
                   DisplayName="scope_id"
                   Name="scope_id"
                   ID="{A1000002-0000-0000-0000-000000000002}"
                   Required="TRUE"
                   EnforceUniqueValues="FALSE">
              <CHOICES>
                <CHOICE>teams_project_channel</CHOICE>
                <CHOICE>teams_safety_compliance</CHOICE>
                <CHOICE>teams_estimating</CHOICE>
                <CHOICE>teams_agent_governance</CHOICE>
                <CHOICE>sp_project_site</CHOICE>
                <CHOICE>sp_intranet</CHOICE>
                <CHOICE>sp_intranet_agent_governance</CHOICE>
                <CHOICE>sp_finance</CHOICE>
                <CHOICE>od_field</CHOICE>
              </CHOICES>
            </Field>

            <!-- access: the level of access granted -->
            <Field Type="Choice"
                   DisplayName="access"
                   Name="access"
                   ID="{A1000003-0000-0000-0000-000000000003}"
                   Required="TRUE"
                   EnforceUniqueValues="FALSE">
              <CHOICES>
                <CHOICE>R</CHOICE>
                <CHOICE>W</CHOICE>
                <CHOICE>R/W</CHOICE>
              </CHOICES>
            </Field>

            <!-- conditional: true = grant has a condition that must be met at runtime -->
            <Field Type="Boolean"
                   DisplayName="conditional"
                   Name="conditional"
                   ID="{A1000004-0000-0000-0000-000000000004}"
                   Required="TRUE">
              <Default>0</Default>
            </Field>

            <!-- condition_notes: human-readable description of the condition -->
            <Field Type="Note"
                   DisplayName="condition_notes"
                   Name="condition_notes"
                   ID="{A1000005-0000-0000-0000-000000000005}"
                   Required="FALSE"
                   NumLines="3"
                   RichText="FALSE" />

            <!-- constitution_ref: pillar/footnote tracing this grant to its source -->
            <Field Type="Text"
                   DisplayName="constitution_ref"
                   Name="constitution_ref"
                   ID="{A1000006-0000-0000-0000-000000000006}"
                   Required="FALSE"
                   MaxLength="100" />

            <!-- effective_date: when this grant was approved and took effect -->
            <Field Type="DateTime"
                   DisplayName="effective_date"
                   Name="effective_date"
                   ID="{A1000007-0000-0000-0000-000000000007}"
                   Required="TRUE"
                   Format="DateOnly" />

            <!-- approved_by: Principal Owner(s) who signed off -->
            <Field Type="Text"
                   DisplayName="approved_by"
                   Name="approved_by"
                   ID="{A1000008-0000-0000-0000-000000000008}"
                   Required="TRUE"
                   MaxLength="100" />

          </pnp:Fields>

          <pnp:Views>
            <View DefaultView="TRUE" Name="All Grants" BaseViewID="1" Type="HTML" Url="Lists/PermissionMatrix/AllItems.aspx">
              <ViewFields>
                <FieldRef Name="agent_id" />
                <FieldRef Name="scope_id" />
                <FieldRef Name="access" />
                <FieldRef Name="conditional" />
                <FieldRef Name="condition_notes" />
                <FieldRef Name="constitution_ref" />
                <FieldRef Name="effective_date" />
                <FieldRef Name="approved_by" />
              </ViewFields>
              <Query>
                <OrderBy>
                  <FieldRef Name="agent_id" />
                  <FieldRef Name="scope_id" />
                </OrderBy>
              </Query>
            </View>
            <View Name="By Agent" BaseViewID="2" Type="HTML" Url="Lists/PermissionMatrix/ByAgent.aspx">
              <ViewFields>
                <FieldRef Name="agent_id" />
                <FieldRef Name="scope_id" />
                <FieldRef Name="access" />
                <FieldRef Name="conditional" />
              </ViewFields>
              <Query>
                <GroupBy Collapse="TRUE">
                  <FieldRef Name="agent_id" />
                </GroupBy>
              </Query>
            </View>
          </pnp:Views>

