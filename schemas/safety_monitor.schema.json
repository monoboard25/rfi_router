{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://monoboard.ai/agent-governance/schemas/safety_monitor.schema.json",
  "title": "Safety Monitor Agent Output",
  "description": "Structured output for the Safety Monitor agent. Scans field data for safety signals without generating citations.",
  "type": "object",
  "required": [
    "run_id",
    "agent_id",
    "agent_version",
    "constitution_version",
    "safety_signals",
    "resolution_path",
    "writes_proposed",
    "outcome"
  ],
  "additionalProperties": false,
  "properties": {
    "run_id": { "type": "string", "format": "uuid" },
    "agent_id": { "type": "string", "const": "safety_monitor" },
    "agent_version": { "type": "string", "pattern": "^\\d+\\.\\d+\\.\\d+$" },
    "constitution_version": { "type": "string", "pattern": "^\\d+\\.\\d+$" },
    "safety_signals": {
      "type": "array",
      "items": {
        "type": "object",
        "required": ["signal_type", "observation", "severity", "source_evidence_uri"],
        "properties": {
          "signal_type": { "type": "string", "enum": ["PPE_VIOLATION", "FALL_HAZARD", "ELECTRICAL_HAZARD", "GOOD_PRACTICE"] },
          "observation": { "type": "string" },
          "severity": { "type": "string", "enum": ["low", "medium", "high", "critical", "info"] },
          "source_evidence_uri": { "type": "string", "format": "uri" }
        }
      }
    },
    "resolution_path": {
      "type": "string",
      "const": "inference"
    },
    "writes_proposed": {
      "type": "array",
      "items": {
        "type": "object",
        "required": ["target_scope", "target_uri", "write_type"],
        "properties": {
          "target_scope": { "type": "string" },
          "target_uri": { "type": "string", "format": "uri" },
          "write_type": { "type": "string" },
          "content_summary": { "type": "string" }
        }
      }
    },
    "escalations_fired": {
      "type": "array",
      "items": {
        "type": "object",
        "required": ["trigger_id", "destination", "halts_write"],
        "properties": {
          "trigger_id": { "type": "string" },
          "destination": { "type": "string" },
          "halts_write": { "type": "boolean" }
        }
      }
    },
    "outcome": {
      "type": "string",
      "enum": ["completed_with_write", "halted_validation", "no_hazards_detected"]
    }
  }
}
